# Configuration Base URLs
# These variables control where the application loads configuration files from

# Local base URL - used for development and when config files are served locally
# Default: /config
# Can be set to different paths or full URLs for different environments
NEXT_PUBLIC_LOCAL_BASE_URL=/config

# CDN base URL - used as fallback when local config is not available
# Default: https://static.kuhandranchatbot.info/api/config (Vercel Static API)
# Set to your production CDN URL

NEXT_PUBLIC_CDN_BASE_URL=https://static.kuhandranchatbot.info/public/config

# Cloudflare Turnstile Configuration
# Get your site key from https://dash.cloudflare.com/
# Set this to your Turnstile site key for the CAPTCHA widget
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAADPER3VGtU9P4SUA

