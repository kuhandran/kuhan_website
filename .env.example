# ─────────────────────────────────────────────
# SITE
# ─────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://www.kuhandranchatbot.info

# ─────────────────────────────────────────────
# EXTERNAL SERVICE URLs  (no trailing slash)
# ─────────────────────────────────────────────
# Static CDN — content, images, config files
NEXT_PUBLIC_STATIC_API_URL=https://static.kuhandranchatbot.info

# Auth service — OTP generation and verification
NEXT_PUBLIC_AUTH_SERVICE_URL=https://auth-services.kuhandranchatbot.info

# Chat service — token exchange and AI chat
NEXT_PUBLIC_CHAT_SERVICE_URL=https://chat-services.kuhandranchatbot.info

# Backend API gateway
NEXT_PUBLIC_BACKEND_API_URL=https://api-gateway-9unh.onrender.com

# IP geolocation (visitor analytics)
NEXT_PUBLIC_IP_API_URL=https://ipapi.co

# ─────────────────────────────────────────────
# CLOUDFLARE  (bot protection + analytics)
# ─────────────────────────────────────────────
# Turnstile site key — get at https://dash.cloudflare.com/ → Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key-here

# Web Analytics beacon token — get at https://dash.cloudflare.com/ → Web Analytics
NEXT_PUBLIC_CF_BEACON_TOKEN=your-cloudflare-beacon-token-here

# ─────────────────────────────────────────────
# EMAIL  (server-side only — never NEXT_PUBLIC_)
# ─────────────────────────────────────────────
# Gmail account used to send emails via nodemailer
EMAIL_USER=your-gmail@gmail.com
# Gmail App Password (NOT your account password)
# Generate at: https://myaccount.google.com/apppasswords
EMAIL_PASSWORD=your-app-password-here
# Where admin notifications are delivered
CONTACT_EMAIL=your-admin-email@example.com
